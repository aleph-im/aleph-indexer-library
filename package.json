{
  "name": "@aleph/library",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "husky install",
    "generate": "./generate.sh",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:rebuild": "npm run clean:all && npm i && npm run test",
    "lint": "eslint --cache --ignore-path .gitignore './packages/**/src/**/*.{js,ts,tsx}'",
    "lint:fix": "npm run lint -- --fix --quiet",
    "build": "npm run clean:dist && lerna run build",
    "clean:deps": "lerna exec -- npx rimraf node_modules && npx rimraf node_modules",
    "clean:dist": "lerna exec -- npx rimraf dist && npx rimraf dist",
    "clean": "npm run clean:dist && npm run clean:deps",
    "deps:fix": "madge --exclude 'dist/(.+)' --circular packages",
    "docs": "typedoc --tsconfig ./tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bs58": "^4.0.1",
    "@types/cors": "^2.8.12",
    "@types/dotenv-defaults": "^2.0.1",
    "@types/express": "^4.17.13",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^27.5.1",
    "@types/lodash-es": "^4.17.6",
    "@types/luxon": "^2.3.2",
    "@types/memdown": "^3.0.0",
    "@types/node": "^17.0.45",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.23.0",
    "@typescript-eslint/parser": "^5.23.0",
    "babel-eslint": "^10.1.0",
    "dotenv": "^16.0.1",
    "dotenv-defaults": "^5.0.0",
    "eslint": "^8.15.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "get-port": "^6.1.2",
    "husky": "^8.0.1",
    "jest": "^28.1.0",
    "lerna": "^8.0.0",
    "lint-staged": "^12.4.1",
    "madge": "^5.0.1",
    "memdown": "^6.1.1",
    "moleculer-repl": "^0.7.1",
    "prettier": "^2.6.2",
    "supertest": "^6.2.3",
    "ts-jest": "^28.0.2",
    "ts-jest-resolver": "^2.0.0",
    "typedoc": "^0.25.1",
    "typescript": "^5.2.2",
    "graphql": "^16.9.0",
    "graphql-request": "^7.1.0"
  },
  "overrides": {
    "uuid": "8.3.2",
    "elliptic": ">=6.6.1",
    "cipher-base": ">=1.0.7",
    "sha.js": ">=2.4.12",
    "pbkdf2": ">=3.1.5",
    "form-data": ">=4.0.4",
    "@babel/helpers": ">=7.26.10",
    "@babel/runtime": ">=7.26.10",
    "cross-spawn": ">=7.0.5",
    "base-x": ">=3.0.11",
    "flatted": ">=3.4.2",
    "nanoid": ">=3.3.8",
    "qs": ">=6.14.2",
    "cookie": ">=0.7.0",
    "path-to-regexp": ">=0.1.12",
    "secp256k1": ">=4.0.4",
    "tough-cookie": ">=4.1.3",
    "brace-expansion": ">=1.1.12 <3",
    "fast-xml-parser": ">=5.5.7",
    "ws": ">=7.5.10",
    "bn.js": ">=4.12.3",
    "node-fetch": ">=2.6.7"
  },
  "peerDependencies": {
    "luxon": "^2.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --cache --fix"
  },
  "workspaces": [
    "packages/aleph-holders",
    "packages/aleph-messages",
    "packages/aleph-credit",
    "packages/aleph-vouchers",
    "packages/brick",
    "packages/indexer-generator",
    "packages/marinade-finance",
    "packages/spl-lending",
    "packages/spl-token",
    "packages/token"
  ]
}