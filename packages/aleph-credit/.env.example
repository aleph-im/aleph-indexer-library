# Required
ALEPH_PAYMENT_ADDRESS=

# Blockchain configuration
INDEXER_BLOCKCHAINS=ethereum           # Use 'ethereum-sepolia' for testnet
INDEXER_MIN_BLOCK_HEIGHT=24136053      # Set to 0 for testnet

# Aleph network
ALEPH_HOST=https://api2.aleph.im
ALEPH_PAYMENT_CHANNEL=ALEPH_CREDIT_STAGING

# Indexer settings
INDEXER_NAMESPACE=aleph-credit
INDEXER_API_PORT=8081
INDEXER_INSTANCES=1
INDEXER_DATA_PATH=

# Transport (optional, for distributed mode)
INDEXER_TRANSPORT=
INDEXER_TCP_URLS=
INDEXER_NATS_URL=
