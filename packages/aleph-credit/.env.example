# Required
ALEPH_PAYMENT_ADDRESS=

# Blockchain configuration
INDEXER_BLOCKCHAINS=ethereum           # Comma-separated: 'ethereum', 'ethereum-sepolia', etc.
INDEXER_MIN_BLOCK_HEIGHT=24136053      # Set to 0 for testnet
INDEXER_CHAINS_CONFIG=                 # Path to chains.yaml (default: ./config/chains.yaml)

# RPC and explorer URLs (required, managed by the framework)
# The framework derives env var names from the blockchain ID:
#   <BLOCKCHAIN_ID>_RPC          - JSON-RPC endpoint
#   <BLOCKCHAIN_ID>_EXPLORER_URL - Block explorer API (e.g. Etherscan) for ABI fetching
# Examples for ethereum-sepolia: ETHEREUM_SEPOLIA_RPC, ETHEREUM_SEPOLIA_EXPLORER_URL
ETHEREUM_RPC=
ETHEREUM_EXPLORER_URL=

# Aleph network
ALEPH_HOST=https://api2.aleph.im
ALEPH_PAYMENT_CHANNEL=ALEPH_CREDIT_STAGING

# Indexer settings
INDEXER_NAMESPACE=aleph-credit
INDEXER_API_PORT=8081
INDEXER_INSTANCES=1
INDEXER_DATA_PATH=

# Transport (optional, for distributed mode)
INDEXER_TRANSPORT=
INDEXER_TCP_URLS=
INDEXER_NATS_URL=
